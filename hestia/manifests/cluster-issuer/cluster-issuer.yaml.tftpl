apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: ${issuer_name}
spec:
  acme:
    server: https://acme-v02.api.letsencrypt.org/directory
    email: ${email}
    privateKeySecretRef:
      name: ${issuer_name}
    solvers:
      - dns01:
          cloudflare:
            apiTokenSecretRef:
              name: ${cloudflare_secret_name}
              key: api-token
