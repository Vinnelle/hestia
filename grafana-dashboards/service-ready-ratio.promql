sum by (namespace, service) (
  label_replace(kube_deployment_status_replicas_available / kube_deployment_spec_replicas, "service", "$1", "deployment", "(.*)")
  or
  label_replace(kube_daemonset_status_number_ready / kube_daemonset_status_desired_number_scheduled, "service", "$1", "daemonset", "(.*)")
  or
  label_replace(kube_statefulset_status_replicas_ready / kube_statefulset_replicas, "service", "$1", "statefulset", "(.*)")
)
